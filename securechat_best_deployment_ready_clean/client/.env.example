VITE_API_URL=http://localhost:8080

# Required for reliable production voice/video calls
# Add every URL supplied by the TURN provider, separated by commas.
# Include UDP/TCP and TURNS port 443 when available.
VITE_TURN_URLS=turn:your-turn-host:80,turn:your-turn-host:443?transport=tcp,turns:your-turn-host:443?transport=tcp
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
# Use "relay" temporarily when testing TURN, then return to "all".
VITE_ICE_TRANSPORT_POLICY=all

# Experimental. Keep false in production until the E2EE beta is security-reviewed.
VITE_E2EE_ENABLED=false
